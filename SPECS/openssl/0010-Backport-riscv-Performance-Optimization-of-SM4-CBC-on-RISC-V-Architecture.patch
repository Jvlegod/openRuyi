+    @{[reverse_order_S $vdata0, $out]}
+    addi $out, $out, $BLOCK_SIZE
+    addi $len, $len, -$BLOCK_SIZE
+
+    li $tmp, $BLOCK_SIZE
+    bgeu $len, $tmp, .Lcbc_dec_single
+    #Save the final IV (in reverse element order)
+    @{[reverse_order_S $vivec, $ivp]}
+.Lcbc_dec_end:
+    ret
