diff --git a/aes/riscv64/ghash_zvkg.S b/aes/riscv64/ghash_zvkg.S
new file mode 100644
index 0000000..1872767
--- /dev/null
+++ b/aes/riscv64/ghash_zvkg.S
@@ -0,0 +1,167 @@
