%define _name           go-version
%define go_import_path  github.com/anchore/go-version

Name:           go-github-anchore-go-version
Version:        1.2.2-0.20200701162849-18adb9c92b9b
Release:        %autorelease
Summary:        Go library packaged for syft dependency resolution
License:        MPL-2.0
URL:            https://github.com/anchore/go-version
#!RemoteAsset
Source0:        %{url}/archive/v%{version}.tar.gz#/%{_name}-%{version}.tar.gz
BuildArch:      noarch
BuildSystem:    golangmodules

BuildOption(prep):  -n %{_name}-%{version}

BuildRequires:  go
BuildRequires:  go-rpm-macros

Provides:       go(github.com/anchore/go-version) = %{version}

%description
Go library packaged for syft dependency resolution.

%files
%license LICENSE*
%doc README*
%{go_sys_gopath}/%{go_import_path}

%changelog
%{?autochangelog}
