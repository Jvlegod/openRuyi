%define _name           go-mtree
%define go_import_path  github.com/vbatts/go-mtree

Name:           go-github-vbatts-go-mtree
Version:        0.7.0
Release:        %autorelease
Summary:        Go library packaged for syft dependency resolution
License:        BSD-3-Clause
URL:            https://github.com/vbatts/go-mtree
#!RemoteAsset
Source0:        %{url}/archive/v%{version}.tar.gz#/%{_name}-%{version}.tar.gz
BuildArch:      noarch
BuildSystem:    golangmodules

BuildOption(prep):  -n %{_name}-%{version}

BuildRequires:  go
BuildRequires:  go-rpm-macros

Provides:       go(github.com/vbatts/go-mtree) = %{version}

%description
Go library packaged for syft dependency resolution.

%files
%license LICENSE*
%doc README*
%{go_sys_gopath}/%{go_import_path}

%changelog
%{?autochangelog}
